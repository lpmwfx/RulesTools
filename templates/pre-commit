#!/usr/bin/env bash
# pre-commit hook — rulestools scanner
# Installed by: rulestools init
#
# Runs the scanner in one-shot mode.
# Exits non-zero (blocking the commit) if there are any errors.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCANNER="$REPO_ROOT/rulestools/cli.py"

if [ ! -f "$SCANNER" ]; then
  echo "rulestools: scanner not found at $SCANNER — skipping"
  exit 0
fi

echo "rulestools: scanning for rule violations..."

# Run scanner — exits 1 if errors found
if ! python "$SCANNER" scan "$REPO_ROOT"; then
  echo ""
  echo "rulestools: commit blocked — fix errors in proj/ISSUES first"
  echo "  Run 'python rulestools/cli.py scan' to see all issues"
  exit 1
fi

echo "rulestools: clean"
