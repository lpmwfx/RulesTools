{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rules: watch",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/rulestools/cli.py",
        "scan",
        "--watch",
        "${workspaceFolder}"
      ],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Rules scanner"
      },
      "problemMatcher": {
        "owner": "rulestools",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Scanning",
          "endsPattern": "issues"
        },
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+): (error|warning|info) ([^:]+): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    },
    {
      "label": "Rules: scan once",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/rulestools/cli.py",
        "scan",
        "${workspaceFolder}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "rulestools",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+): (error|warning|info) ([^:]+): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    }
  ]
}
